CEREBRAS_API_KEY=replace_with_hackathon_key
CEREBRAS_MODEL=gemma-4-31b
CEREBRAS_REASONING_EFFORT=none
CEREBRAS_SDK_TIMEOUT_SECONDS=30
CUE_API_HOST=127.0.0.1
CUE_API_PORT=8765
CUE_BACKEND_MODE=local
CUE_PRIVACY_MODE=strict
CUE_CONFIRM_ACTIONS=true
CUE_APPROVAL_TIER=confirm_each_action
CUE_HIGH_RISK_APPROVAL=guardian
CUE_REVIEWER_MODE=false
CUE_SAVE_SCREENSHOTS=false
CUE_BLOCK_SCREENSHOTS_FOR_SENSITIVE_APPS=true
CUE_AUDIT_LOG=true
CUE_AUDIT_LOG_REDACTED=true
CUE_AUDIT_LOG_PATH=.cue/audit.jsonl
CUE_SESSION_STATE_PATH=.cue/session.json
CUE_MEMORY_ENABLED=true
CUE_MAX_WORKFLOW_STEPS=5
CUE_MAX_ACTIONS_PER_STEP=1
CUE_REQUIRE_WORKFLOW_APPROVAL=true
CUE_VERIFY_AFTER_EACH_ACTION=true
CUE_FOCUS_CHECK_REQUIRED=true
CUE_REPORT_CURSOR_AND_FOCUS=true
CUE_ALLOW_APP_LAUNCH=true
CUE_ALLOW_BROWSER_NAVIGATION=true
CUE_ALLOW_DOCUMENT_EDITING=true
CUE_ALLOW_TERMINAL_READONLY=true
CUE_ALLOW_TERMINAL_WRITE=true
CUE_ENABLE_VOICE_INPUT=false
CUE_SPEAK=true
CUE_YOLO_MODE=false
CUE_ALLOWED_APPS=TextEdit,Preview,Safari,Google Chrome,Terminal,Finder,Notes,Calendar,Reminders,Mail,Messages,Contacts,FaceTime,Maps,Photos,Music,Podcasts,TV,Books,Freeform,Calculator,Dictionary,Stickies,Voice Memos,QuickTime Player,Pages,Numbers,Keynote,Microsoft Word,Microsoft Excel,Microsoft PowerPoint,Microsoft Outlook,Microsoft Teams,Slack,Discord,Zoom,Notion,Obsidian,Todoist,Things,Arc,Firefox,Brave Browser,Microsoft Edge,Visual Studio Code,Cursor,Xcode,GitHub Desktop,Docker,Postman,iTerm,Warp
CUE_BLOCKED_APPS=Keychain Access,1Password,Bitwarden,System Settings
CUE_ALLOWED_DOMAINS=localhost,127.0.0.1,google.com,github.com,openai.com,cerebras.ai,apple.com,microsoft.com,slack.com,notion.so,atlassian.net,linear.app,figma.com,vercel.app,railway.app,stackoverflow.com,wikipedia.org,youtube.com
